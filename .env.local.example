# This file contains example environment variables.
# For your development environment, create a `.env.local` file
# and add your actual credentials there.

# URL base de la aplicacion
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Secreto para encriptacion de sesiones en Auth.js
# Generable usando: openssl rand -base64 32
AUTH_SECRET="tu_secreto_generado"

# Credenciales de Google OAuth (Auth.js)
AUTH_GOOGLE_ID="tu_id_de_cliente.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="tu_secreto_de_google"

# MongoDB Connection String from MongoDB Atlas
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster-url>/<db-name>?retryWrites=true&w=majority"
# The name of the database to use.
MONGODB_DB="ledger_lite"

# Enlaces para el dialogo de soporte y metadatos
NEXT_PUBLIC_CAFECITO_USER="tu_usuario_de_cafecito"
NEXT_PUBLIC_MERCADOPAGO_URL="https://link.mercadopago.com.ar/tu_usuario"
NEXT_PUBLIC_PORTFOLIO_URL="https://tu_portfolio.com"
NEXT_PUBLIC_GITHUB_REPO_URL="https://github.com/tu_usuario/tu_repositorio"
NEXT_PUBLIC_PAYPAL_URL="https://paypal.me/tuUsuario"

# Telegram Bot (Opcional)
TELEGRAM_BOT_TOKEN="tu_token_de_botfather"
TELEGRAM_WEBHOOK_SECRET="un_secreto_aleatorio_para_seguridad"

# LLM (Para el NLP de transcripcion de transacciones de Telegram)
GEMINI_API_KEY="tu_api_key_de_gemini"
